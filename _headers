# Cloudflare response headers — QuickScale Media
#
# The repo uses PRODUCTION URLs (quickscalem.com). While we test on scalequick.cc (a
# noindexed backup/staging domain), the whole site is set noindex.
#
# AT LAUNCH (attaching quickscalem.com): delete the "X-Robots-Tag: noindex" line in the
# /* block below so the live site is indexable.
#
# The CSP already allows the live integrations: Supabase (form relay + admin), Google Fonts,
# Cloudflare Turnstile, Meta Pixel, GA4, and the GoHighLevel calendar embed
# (api.leadconnectorhq.com / link.msgsndr.com / widgets.leadconnectorhq.com in frame-src).
# If your GHL calendar is on a custom domain, add it to frame-src. Verify in DevTools —
# CSP is easy to loosen if anything legitimate is blocked.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Robots-Tag: noindex
  Content-Security-Policy: default-src 'self'; script-src 'self' https://challenges.cloudflare.com https://connect.facebook.net https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://www.facebook.com https://*.supabase.co; media-src 'self' https://*.supabase.co; connect-src 'self' https://*.supabase.co https://challenges.cloudflare.com https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://www.facebook.com; frame-src https://challenges.cloudflare.com https://api.leadconnectorhq.com https://link.msgsndr.com https://widgets.leadconnectorhq.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'

# Admin is never indexed, on any domain (overrides the noindex value above for /admin/*).
# Stricter near-self CSP: the admin loads only vendored JS (Supabase) + Google Fonts and talks
# to its Supabase project (auth/db/storage/functions). Put it behind Cloudflare Access as well.
/admin/*
  X-Robots-Tag: noindex, nofollow
  X-Frame-Options: DENY
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.supabase.co; connect-src 'self' https://*.supabase.co; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'

# Long-lived static assets — cache with revalidation. Filenames are unhashed, so keep a
# moderate max-age (a CSS/JS edit still propagates within a day). Raise to immutable/1yr
# only after introducing content-hashed filenames.
/assets/*
  Cache-Control: public, max-age=86400, must-revalidate
